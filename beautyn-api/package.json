{
  "name": "beautyn-api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "prisma generate --schema=./prisma/schema.prisma && nest build && tsc-alias -p tsconfig.json",
    "build:railway": "prisma generate --schema=./prisma/schema.prisma && nest build && tsc-alias -p tsconfig.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "NODE_ENV=${NODE_ENV:-production} dotenv -e .env.${NODE_ENV:-production} -- prisma generate --schema=./prisma/schema.prisma && npm run build && NODE_ENV=${NODE_ENV:-production} node dist/src/main.js",
    "start:dev": "NODE_ENV=dev dotenv -e .env.dev -- prisma generate --schema=./prisma/schema.prisma && NODE_ENV=dev dotenv -e .env.dev -- nest start --watch",
    "start:dev:redis": "docker compose up -d redis && NODE_ENV=dev dotenv -e .env.dev -- prisma generate --schema=./prisma/schema.prisma && NODE_ENV=dev dotenv -e .env.dev -- nest start --watch",
    "start:local": "NODE_ENV=local dotenv -e .env.local -- prisma generate --schema=./prisma/schema.prisma && NODE_ENV=local dotenv -e .env.local -- nest start --watch",
    "start:local:redis": "docker compose up -d redis && NODE_ENV=local dotenv -e .env.local -- prisma generate --schema=./prisma/schema.prisma && NODE_ENV=local dotenv -e .env.local -- nest start --watch",
    "local:redis:down": "docker compose stop redis || true",
    "local:redis": "docker compose up -d redis",
    "start:stage": "NODE_ENV=staging dotenv -e .env.staging -- prisma generate --schema=./prisma/schema.prisma && npm run build && NODE_ENV=staging node dist/src/main.js",
    "start:stage:redis": "docker compose up -d redis && npm run start:stage",
    "start:prod": "NODE_ENV=production dotenv -e .env.production -- prisma generate --schema=./prisma/schema.prisma && npm run build && NODE_ENV=production node dist/src/main.js",
    "start:prod:redis": "docker compose up -d redis && npm run start:prod",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json --reporters=default --reporters=./scripts/jest-summary-reporter.js",
    "db:dev:migrate": "dotenv -e .env.dev -- npx prisma migrate dev",
    "db:dev:deploy": "dotenv -e .env.dev -- npx prisma migrate deploy",
    "db:dev:reset": "dotenv -e .env.dev -- npx prisma migrate reset --force",
    "db:local:migrate": "dotenv -e .env.local -- npx prisma migrate dev",
    "db:local:deploy": "dotenv -e .env.local -- npx prisma migrate deploy",
    "db:local:reset": "dotenv -e .env.local -- npx prisma migrate reset --force",
    "reset:local:users": "NODE_ENV=local dotenv -e .env.local -- ts-node -r tsconfig-paths/register scripts/reset-local.ts",
    "reset:dev:users": "NODE_ENV=dev dotenv -e .env.dev -- ts-node -r tsconfig-paths/register scripts/reset-local.ts",
    "db:stage:migrate": "dotenv -e .env.stage -- npx prisma migrate dev",
    "db:stage:deploy": "dotenv -e .env.stage -- npx prisma migrate deploy",
    "db:prod:deploy": "dotenv -e .env.prod -- npx prisma migrate deploy",
    "db:deploy": "npx prisma migrate deploy",
    "db:status:dev": "dotenv -e .env.dev -- npx prisma migrate status",
    "promote:admin:local": "NODE_ENV=local dotenv -e .env.local -- ts-node -r tsconfig-paths/register scripts/promote-admin.ts",
    "promote:admin:dev": "NODE_ENV=dev dotenv -e .env.dev -- ts-node -r tsconfig-paths/register scripts/promote-admin.ts",
    "seed:local": "NODE_ENV=local dotenv -e .env.local -- ts-node -r tsconfig-paths/register scripts/seed-local.ts",
    "cleanup:local": "NODE_ENV=local dotenv -e .env.local -- ts-node -r tsconfig-paths/register scripts/cleanup-local.ts",
    "seed:search-salons:local": "NODE_ENV=local dotenv -e .env.local -- ts-node -r tsconfig-paths/register scripts/seed-search-salons.ts",
    "seed:search-salons:local:cleanup": "NODE_ENV=local dotenv -e .env.local -- ts-node -r tsconfig-paths/register scripts/cleanup-search-salons.ts",
    "queue:local:inspect": "NODE_ENV=local dotenv -e .env.local -- ts-node -r tsconfig-paths/register src/scripts/queue-inspect.ts",
    "queue:dev:inspect": "NODE_ENV=dev dotenv -e .env.dev -- ts-node -r tsconfig-paths/register src/scripts/queue-inspect.ts",
    "queue:dev:failed:clear": "NODE_ENV=dev dotenv -e .env.dev -- ts-node -r tsconfig-paths/register src/scripts/queue-inspect.ts --clean-failed",
    "queue:local:failed:clear": "NODE_ENV=local dotenv -e .env.local -- ts-node -r tsconfig-paths/register src/scripts/queue-inspect.ts --clean-failed",
    "worker:initial:local": "NODE_ENV=local dotenv -e .env.local -- ts-node -r tsconfig-paths/register libs/crm/sync-scheduler/src/workers/initial-sync.worker.ts",
    "worker:initial:dev": "NODE_ENV=dev dotenv -e .env.dev -- ts-node -r tsconfig-paths/register libs/crm/sync-scheduler/src/workers/initial-sync.worker.ts",
    "worker:categories:local": "NODE_ENV=local dotenv -e .env.local -- ts-node -r tsconfig-paths/register libs/crm/sync-scheduler/src/workers/categories-sync.worker.ts",
    "worker:categories:dev": "NODE_ENV=dev dotenv -e .env.dev -- ts-node -r tsconfig-paths/register libs/crm/sync-scheduler/src/workers/categories-sync.worker.ts",
    "worker:services:local": "NODE_ENV=local dotenv -e .env.local -- ts-node -r tsconfig-paths/register libs/crm/sync-scheduler/src/workers/services-sync.worker.ts",
    "worker:services:dev": "NODE_ENV=dev dotenv -e .env.dev -- ts-node -r tsconfig-paths/register libs/crm/sync-scheduler/src/workers/services-sync.worker.ts",
    "worker:workers:local": "NODE_ENV=local dotenv -e .env.local -- ts-node -r tsconfig-paths/register libs/crm/sync-scheduler/src/workers/workers-sync.worker.ts",
    "worker:workers:dev": "NODE_ENV=dev dotenv -e .env.dev -- ts-node -r tsconfig-paths/register libs/crm/sync-scheduler/src/workers/workers-sync.worker.ts",
    "worker:bookings:local": "NODE_ENV=local dotenv -e .env.local -- ts-node -r tsconfig-paths/register libs/crm/sync-scheduler/src/workers/bookings-sync.worker.ts",
    "worker:bookings:dev": "NODE_ENV=dev dotenv -e .env.dev -- ts-node -r tsconfig-paths/register libs/crm/sync-scheduler/src/workers/bookings-sync.worker.ts",
    "worker:cron:local": "NODE_ENV=local dotenv -e .env.local -- ts-node -r tsconfig-paths/register libs/crm/sync-scheduler/src/workers/cron-diff.worker.ts",
    "worker:cron:dev": "NODE_ENV=dev dotenv -e .env.dev -- ts-node -r tsconfig-paths/register libs/crm/sync-scheduler/src/workers/cron-diff.worker.ts",
    "worker:initial:stage": "NODE_ENV=staging dotenv -e .env.staging -- ts-node -r tsconfig-paths/register libs/crm/sync-scheduler/src/workers/initial-sync.worker.ts",
    "worker:initial:prod": "NODE_ENV=production dotenv -e .env.production -- ts-node -r tsconfig-paths/register libs/crm/sync-scheduler/src/workers/initial-sync.worker.ts",
    "worker:categories:stage": "NODE_ENV=staging dotenv -e .env.staging -- ts-node -r tsconfig-paths/register libs/crm/sync-scheduler/src/workers/categories-sync.worker.ts",
    "worker:categories:prod": "NODE_ENV=production dotenv -e .env.production -- ts-node -r tsconfig-paths/register libs/crm/sync-scheduler/src/workers/categories-sync.worker.ts",
    "worker:services:stage": "NODE_ENV=staging dotenv -e .env.staging -- ts-node -r tsconfig-paths/register libs/crm/sync-scheduler/src/workers/services-sync.worker.ts",
    "worker:services:prod": "NODE_ENV=production dotenv -e .env.production -- ts-node -r tsconfig-paths/register libs/crm/sync-scheduler/src/workers/services-sync.worker.ts",
    "worker:workers:stage": "NODE_ENV=staging dotenv -e .env.staging -- ts-node -r tsconfig-paths/register libs/crm/sync-scheduler/src/workers/workers-sync.worker.ts",
    "worker:workers:prod": "NODE_ENV=production dotenv -e .env.production -- ts-node -r tsconfig-paths/register libs/crm/sync-scheduler/src/workers/workers-sync.worker.ts",
    "worker:bookings:stage": "NODE_ENV=staging dotenv -e .env.staging -- ts-node -r tsconfig-paths/register libs/crm/sync-scheduler/src/workers/bookings-sync.worker.ts",
    "worker:bookings:prod": "NODE_ENV=production dotenv -e .env.production -- ts-node -r tsconfig-paths/register libs/crm/sync-scheduler/src/workers/bookings-sync.worker.ts",
    "worker:cron:stage": "NODE_ENV=staging dotenv -e .env.staging -- ts-node -r tsconfig-paths/register libs/crm/sync-scheduler/src/workers/cron-diff.worker.ts",
    "worker:cron:prod": "NODE_ENV=production dotenv -e .env.production -- ts-node -r tsconfig-paths/register libs/crm/sync-scheduler/src/workers/cron-diff.worker.ts",
    "worker:salons:local": "NODE_ENV=local dotenv -e .env.local -- ts-node -r tsconfig-paths/register libs/crm/sync-scheduler/src/workers/salons-sync.worker.ts",
    "worker:salons:dev": "NODE_ENV=dev dotenv -e .env.dev -- ts-node -r tsconfig-paths/register libs/crm/sync-scheduler/src/workers/salons-sync.worker.ts",
    "worker:salons:stage": "NODE_ENV=staging dotenv -e .env.staging -- ts-node -r tsconfig-paths/register libs/crm/sync-scheduler/src/workers/salons-sync.worker.ts",
    "worker:salons:prod": "NODE_ENV=production dotenv -e .env.production -- ts-node -r tsconfig-paths/register libs/crm/sync-scheduler/src/workers/salons-sync.worker.ts",
    "worker:local": "concurrently -n initial,categories,services,workers,bookings,salons,cron -c green,magenta,cyan,blue,red,white,yellow \"npm:worker:initial:local\" \"npm:worker:categories:local\" \"npm:worker:services:local\" \"npm:worker:workers:local\" \"npm:worker:bookings:local\" \"npm:worker:salons:local\" \"npm:worker:cron:local\"",
    "worker:dev": "concurrently -n initial,categories,services,workers,bookings,salons,cron -c green,magenta,cyan,blue,red,white,yellow \"npm:worker:initial:dev\" \"npm:worker:categories:dev\" \"npm:worker:services:dev\" \"npm:worker:workers:dev\" \"npm:worker:bookings:dev\" \"npm:worker:salons:dev\" \"npm:worker:cron:dev\"",
    "worker:stage": "concurrently -n initial,categories,services,workers,bookings,salons,cron -c green,magenta,cyan,blue,red,white,yellow \"npm:worker:initial:stage\" \"npm:worker:categories:stage\" \"npm:worker:services:stage\" \"npm:worker:workers:stage\" \"npm:worker:bookings:stage\" \"npm:worker:salons:stage\" \"npm:worker:cron:stage\"",
    "worker:prod": "concurrently -n initial,categories,services,workers,bookings,salons,cron -c green,magenta,cyan,blue,red,white,yellow \"npm:worker:initial:prod\" \"npm:worker:categories:prod\" \"npm:worker:services:prod\" \"npm:worker:workers:prod\" \"npm:worker:bookings:prod\" \"npm:worker:salons:prod\" \"npm:worker:cron:prod\"",
    "up:local": "concurrently -k -n api,workers -c cyan,magenta \"npm:start:local:redis\" \"npm:worker:local\"",
    "up:dev": "concurrently -k -n api,workers -c cyan,magenta \"npm:start:dev:redis\" \"npm:worker:dev\"",
    "up:stage": "concurrently -k -n api,workers -c cyan,magenta \"npm:start:stage:redis\" \"npm:worker:stage\"",
    "up:prod": "concurrently -k -n api,workers -c cyan,magenta \"npm:start:prod:redis\" \"npm:worker:prod\"",
    "start:railway": "node dist/src/main.js"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.2.0",
    "@prisma/client": "^6.14.0",
    "@supabase/supabase-js": "^2.53.0",
    "argon2": "^0.43.1",
    "bullmq": "^5.58.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "jose": "^6.0.12",
    "libphonenumber-js": "^1.12.10",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.7",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "dotenv-cli": "^10.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "jsonwebtoken": "^9.0.2",
    "prettier": "^3.4.2",
    "prisma": "^6.16.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.10",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "wait-on": "^8.0.4"
  }
}
