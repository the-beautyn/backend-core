# =================================
# BEAUTYN API - Environment Configuration
# =================================

# Node Environment
NODE_ENV= # development | staging | production

# =================================
# DATABASE CONFIGURATION
# =================================
# PostgreSQL Database URL
DATABASE_URL=
DIRECT_URL=

# =================================
# SERVER CONFIGURATION
# =================================
# Port the server will run on
PORT= # default 3000 locally; Railway injects PORT dynamically
# Base url
APP_URL=

# =================================
# SUPABASE
# =================================
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# =================================
# ALTEGIO
# =================================
PAIRING_CODE_PEPPER=
ALTEGIO_APPLICATION_ID=
ALTEGIO_BEARER_SECRET=

# =================================
# Debug
# =================================
ERROR_DETAILS_ENABLED=