# =================================
# BEAUTYN API - Environment Configuration
# =================================

# Node Environment
NODE_ENV= # development | staging | production

# =================================
# DATABASE CONFIGURATION
# =================================
# PostgreSQL Database URL
DATABASE_URL=
DIRECT_URL=

# =================================
# SERVER CONFIGURATION
# =================================
# Port the server will run on
PORT= # default 3000 locally; Railway injects PORT dynamically
# Base url
APP_URL=

# =================================
# SUPABASE
# =================================
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# =================================
# ALTEGIO
# =================================
PAIRING_CODE_PEPPER=
ALTEGIO_APPLICATION_ID=
ALTEGIO_BEARER=
ALTEGIO_USER=

# =================================
# Debug
# =================================
ERROR_DETAILS_ENABLED=
LOG_LEVEL=
SERVICE_NAME=

# =================================
# CRM
# =================================
NODE_CRM_MASTER_KEY=
CRM_CAPS_PATH=(optional)
CRM_RETRY_ATTEMPTS=(default 3)
CRM_RETRY_BASE_DELAY_MS=(default 500)
CRM_RETRY_MAX_DELAY_MS=(default 4000)
CRM_RETRY_JITTER=(default true)