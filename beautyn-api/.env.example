# =================================
# BEAUTYN API - Environment Configuration
# =================================

# Node Environment
NODE_ENV= # development | staging | production

# =================================
# DATABASE CONFIGURATION
# =================================
# PostgreSQL Database URL
DATABASE_URL=
DIRECT_URL=

# =================================
# SERVER CONFIGURATION
# =================================
# Port the server will run on
PORT= # default 3000 locally; Railway injects PORT dynamically
# Base url
APP_URL=

# =================================
# INTERNAL API
# =================================
INTERNAL_API_BASE_URL=
INTERNAL_API_KEY=

# =================================
# SUPABASE
# =================================
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# =================================
# ALTEGIO
# =================================
PAIRING_CODE_PEPPER=
ALTEGIO_APPLICATION_ID=
ALTEGIO_BEARER=
ALTEGIO_USER=
ALTEGIO_API_BASE=

# =================================
# EASYWEEK
# =================================
EASYWEEK_API_BASE=

# =================================
# Debug
# =================================
ERROR_DETAILS_ENABLED=
SERVICE_NAME=
LOG_LEVEL=
LOG_PRETTY=
LOG_LEVEL=

# =================================
# CRM
# =================================
NODE_CRM_MASTER_KEY=
CRM_CAPS_PATH=(optional)
CRM_RETRY_ATTEMPTS=(default 3)
CRM_RETRY_BASE_DELAY_MS=(default 500)
CRM_RETRY_MAX_DELAY_MS=(default 4000)
CRM_RETRY_JITTER=(default true)
CRM_SYNC_DEFAULT_CRON=(default '0 2 * * *')

## Workers
CRM_WORKER_CONCURRENCY=
CRM_SYNC_RATE_MAX=
CRM_SYNC_RATE_DURATION_MS=

# =================================
# Redis
# =================================
REDIS_URL=

# =================================
# SMS
# =================================
MOCK_SMS=

# =================================
# Twilio
# =================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# =================================
# Google OAuth
# =================================
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# =================================
# Throttling (per-user for authenticated, per-IP for anonymous)
# All values optional — defaults in src/shared/throttler/app-throttler.module.ts
# =================================
# OTP send/resend burst — short window, blocks rapid re-sends
THROTTLE_OTP_BURST_LIMIT=    # default 1
THROTTLE_OTP_BURST_TTL_MS=   # default 60000 (1 min)
# OTP send/resend hourly cap
THROTTLE_OTP_HOUR_LIMIT=     # default 10
THROTTLE_OTP_HOUR_TTL_MS=    # default 3600000 (1 hour)
# OTP verify attempts
THROTTLE_OTP_VERIFY_LIMIT=   # default 10
THROTTLE_OTP_VERIFY_TTL_MS=  # default 300000 (5 min)
# check-email per-IP (anti-enumeration)
THROTTLE_EMAIL_CHECK_LIMIT=  # default 10
THROTTLE_EMAIL_CHECK_TTL_MS= # default 60000 (1 min)