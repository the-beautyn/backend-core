{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "plugins": [
      {
        "name": "@nestjs/swagger",
        "options": {
          "classValidatorShim": true
        }
      }
    ],
    "assets": [
      {
        "include": "libs/crm/capability-registry/src/capabilities.defaults.json",
        "outDir": "dist/libs/crm/capability-registry/src"
      }
    ]
  }
}
