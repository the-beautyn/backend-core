generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled, transaction mode (6543) + ?pgbouncer=true
  directUrl = env("DIRECT_URL") // direct/session mode (5432) for migrations
}

model SubscriptionPlan {
  id           String   @id @db.Uuid
  name         String   @db.VarChar(120)
  description  String
  priceCents   Int      @map("price_cents")
  currency     String   @db.Char(3)
  durationDays Int      @map("duration_days")
  features     Json
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  users        Users[]

  @@map("subscription_plan")
}

model Users {
  id                    String            @id @db.Uuid
  email                 String            @unique @db.VarChar(255)
  role                  UserRole          @default(client)
  name                  String?           @db.VarChar(100)
  secondName            String?           @map("second_name") @db.VarChar(100)
  phone                 String?           @db.VarChar(30)
  avatarUrl             String?           @map("avatar_url")
  isProfileCreated      Boolean           @default(false) @map("is_profile_created")
  isOnboardingCompleted Boolean           @default(false) @map("is_onboarding_completed")
  subscriptionId        String?           @map("subscription_id") @db.Uuid
  crmId                 String?           @map("crm_id")
  createdAt             DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime          @default(now()) @map("updated_at") @db.Timestamptz(6)
  subscriptionPlan      SubscriptionPlan? @relation(fields: [subscriptionId], references: [id])
  onboardingStep        OnboardingStep?
  salon                 Salon?            @relation("UserSalons")
  searchHistory         SearchHistory[]

  @@map("users")
}

/// Enum mapped to existing Postgres type `user_role`
enum UserRole {
  client @map("client")
  owner  @map("owner")
  admin  @map("admin")

  @@map("user_role")
}

enum OnboardingStepState {
  CRM
  SALON_PROFILE
  SUBSCRIPTION
  COMPLETED

  @@map("onboarding_step_state")
}

enum CrmSalonChangeStatus {
  pending   @map("pending")
  accepted  @map("accepted")
  dismissed @map("dismissed")

  @@map("crm_salon_change_status")
}

model OnboardingStep {
  id              String              @id @default(uuid()) @db.Uuid
  userId          String              @unique @map("user_id") @db.Uuid
  crmConnected    Boolean             @default(false) @map("crm_connected")
  salonCreated    Boolean             @default(false) @map("salon_created")
  subscriptionSet Boolean             @default(false) @map("subscription_set")
  currentStep     OnboardingStepState @default(CRM) @map("current_step")
  completed       Boolean             @default(false)
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  user Users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("onboarding_step")
}

model Salon {
  id              String    @id @default(uuid()) @db.Uuid
  // CRM link (draft onboarding support)
  // externalSalonId stores provider-specific external id (stringified)
  externalSalonId String?   @map("external_salon_id")
  // provider stores which CRM this salon is linked to (e.g., 'ALTEGIO' | 'EASYWEEK')
  provider        String?   @map("provider")
  // owner user link (used for onboarding flows)
  ownerUserId     String?   @map("owner_user_id") @db.Uuid
  owner           Users?    @relation("UserSalons", fields: [ownerUserId], references: [id], onDelete: SetNull)
  name            String?
  description     String?   @map("description")
  addressLine     String?   @map("address_line")
  city            String?
  country         String?   @db.VarChar(64)
  latitude        Decimal?  @db.Decimal(9, 6)
  longitude       Decimal?  @db.Decimal(9, 6)
  timezone        String?   @map("timezone")
  phone           String?
  email           String?
  ratingAvg       Decimal?  @map("rating_avg") @db.Decimal(2, 1)
  ratingCount     Int?      @map("rating_count")
  minPriceCents   Int?      @map("min_price_cents")
  maxPriceCents   Int?      @map("max_price_cents")
  openHoursJson   Json?     @map("open_hours_json")
  workingSchedule String?   @map("working_schedule")
  imagesCount     Int?      @map("images_count")
  coverImageUrl   String?   @map("cover_image_url")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  images             SalonImage[]
  categories         Category[]
  services           Service[]
  workers            Worker[]
  bookings           Booking[]
  crmHashes          CrmSalonLastHash[]
  crmChangeProposals CrmSalonChangeProposal[]
  crmSnapshots       CrmSalonSnapshot[]
  searchHistory      SearchHistory[]

  @@unique([ownerUserId], map: "uniq_salon_owner")
  @@index([latitude, longitude])
  @@index([ownerUserId], map: "idx_salon_owner")
  @@map("salons")
}

model SalonImage {
  id        String   @id @default(uuid()) @db.Uuid
  salonId   String   @map("salon_id") @db.Uuid
  imageUrl  String   @map("image_url")
  caption   String?
  sortOrder Int?     @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  salon Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@index([salonId, sortOrder])
  @@map("salon_images")
}

model Category {
  id            String   @id @default(uuid()) @db.Uuid
  salonId       String   @map("salon_id") @db.Uuid
  crmCategoryId String   @map("crm_category_id") @db.VarChar(64)
  name          String   @db.VarChar(120)
  color         String?  @db.VarChar(7)
  sortOrder     Int?     @map("sort_order")
  serviceIds    String[] @default([]) @map("service_ids") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  salon    Salon                   @relation(fields: [salonId], references: [id], onDelete: Cascade)
  services Service[]
  mapping  SalonCategoryMapping? @relation("SalonCategoryMappingCategory")

  @@index([salonId, sortOrder], map: "idx_category_salon_sort")
  @@map("categories")
}

model AppCategory {
  id         String   @id @default(uuid()) @db.Uuid
  slug       String   @unique @db.VarChar(120)
  name       String   @db.VarChar(160)
  keywords   String[] @default([]) @db.VarChar(160)
  sortOrder  Int?     @map("sort_order")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  mappings SalonCategoryMapping[]

  @@index([isActive, sortOrder])
  @@map("app_categories")
}

enum SalonCategoryMappingUpdatedBy {
  system
  owner
}

model SalonCategoryMapping {
  id               String                        @id @default(uuid()) @db.Uuid
  salonCategoryId  String                        @map("salon_category_id") @db.Uuid
  appCategoryId    String?                       @map("app_category_id") @db.Uuid
  autoMatched      Boolean                       @default(false) @map("auto_matched")
  confidence       Float?                        @map("confidence")
  updatedBy        SalonCategoryMappingUpdatedBy @default(system) @map("updated_by")
  createdAt        DateTime                      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime                      @updatedAt @map("updated_at") @db.Timestamptz(6)

  salonCategory Category     @relation("SalonCategoryMappingCategory", fields: [salonCategoryId], references: [id], onDelete: Cascade)
  appCategory   AppCategory? @relation(fields: [appCategoryId], references: [id], onDelete: SetNull)

  @@unique([salonCategoryId])
  @@index([appCategoryId])
  @@map("salon_category_mappings")
}

model Service {
  id           String   @id @default(uuid()) @db.Uuid
  salonId      String   @map("salon_id") @db.Uuid
  crmServiceId String   @map("crm_service_id")
  categoryId   String?  @map("category_id") @db.Uuid
  name         String   @db.VarChar(160)
  description  String?
  duration     Int
  price        Int
  currency     String   @db.Char(3)
  sortOrder    Int?     @map("sort_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  salon        Salon           @relation(fields: [salonId], references: [id], onDelete: Cascade)
  category     Category?       @relation(fields: [categoryId], references: [id])
  workerLinks  WorkerService[]

  @@index([salonId, crmServiceId], map: "services_salon_crm_id_idx")
  @@index([salonId, isActive])
  @@index([categoryId, isActive])
  @@map("services")
}

model Worker {
  id           String   @id @default(uuid()) @db.Uuid
  salonId      String   @map("salon_id") @db.Uuid
  crmWorkerId  String?  @map("crm_worker_id") @db.VarChar(128)
  firstName    String   @map("first_name") @db.VarChar(100)
  lastName     String   @map("last_name") @db.VarChar(100)
  position     String?  @db.VarChar(160)
  role         String?  @db.VarChar(100)
  description  String?  @db.Text
  email        String?  @unique @db.VarChar(255)
  phone        String?  @unique @db.VarChar(30)
  photoUrl     String?  @map("photo_url")
  workingSchedule Json? @map("work_schedule")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  salon    Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)
  services WorkerService[]
  bookings Booking[]

  @@index([salonId, firstName])
  @@index([salonId, lastName])
  @@index([salonId, crmWorkerId])
  @@map("workers")
}

model WorkerService {
  id             String  @id @default(uuid())
  serviceId      String  @map("service_id") @db.Uuid
  workerId       String? @map("worker_id") @db.Uuid
  remoteWorkerId String? @map("remote_worker_id") @db.VarChar(128)

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  worker  Worker? @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([serviceId, workerId], map: "worker_services_service_worker_unique")
  @@unique([serviceId, remoteWorkerId], map: "worker_services_service_remote_unique")
  @@map("worker_services")
}

model Booking {
  id            String   @id @default(uuid()) @db.Uuid
  salonId       String   @map("salon_id") @db.Uuid
  userId        String?  @map("user_id") @db.Uuid
  workerId      String?  @map("worker_id") @db.Uuid
  status        String   @default("created")
  datetime      DateTime @map("datetime") @db.Timestamptz(6)
  endDatetime   DateTime? @map("end_datetime") @db.Timestamptz(6)
  comment       String?  @map("comment")
  attendance    Int?     @default(1)
  crmType       String?  @map("crm_type")
  crmRecordId   String?  @map("crm_record_id")
  crmCompanyId  String?  @map("crm_company_id")
  crmStaffId    String?  @map("crm_staff_id")
  crmServiceIds Json?    @map("crm_service_ids")
  serviceIds    Json?    @map("service_ids")
  shortLink     String?  @map("short_link")
  crmPayload    Json?    @map("crm_payload")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  salon  Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)
  worker Worker? @relation(fields: [workerId], references: [id], onDelete: SetNull)
  easyweekDetails EasyweekBookingDetails?
  altegioDetails AltegioBookingDetails?

  @@index([salonId], map: "bookings_salon_idx")
  @@unique([crmType, crmRecordId], map: "bookings_crm_type_record_unique")
  @@map("bookings")
}

model EasyweekBookingDetails {
  bookingId       String   @id @map("booking_id") @db.Uuid
  booking         Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  rawPayload      Json?    @map("raw_payload")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  links           EasyweekBookingLink[]
  duration        EasyweekBookingDuration?
  orderedServices EasyweekOrderedService[]
  order           EasyweekBookingOrder?

  @@map("easyweek_booking_details")
}

model EasyweekBookingLink {
  id        String   @id @default(uuid()) @db.Uuid
  detailsId String   @map("extra_id") @db.Uuid
  type      String?  @map("type")
  url       String   @map("url")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  details EasyweekBookingDetails @relation(fields: [detailsId], references: [bookingId], onDelete: Cascade)

  @@index([detailsId], map: "easyweek_booking_links_extra_idx")
  @@map("easyweek_booking_links")
}

model EasyweekBookingDuration {
  detailsId String   @id @map("extra_id") @db.Uuid
  details   EasyweekBookingDetails @relation(fields: [detailsId], references: [bookingId], onDelete: Cascade)
  value     Int?     @map("value")
  label     String?  @map("label")
  iso8601   String?  @map("iso_8601")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("easyweek_booking_durations")
}

model EasyweekBookingOrder {
  detailsId String   @id @map("booking_id") @db.Uuid
  details   EasyweekBookingDetails @relation(fields: [detailsId], references: [bookingId], onDelete: Cascade)
  payload   Json?    @map("payload")
  tax       Json?    @map("tax")
  subtotal  Int?     @map("subtotal")
  subtotalFormatted   String? @map("subtotal_formatted")
  amountPaid          Int?    @map("amount_paid")
  amountPaidFormatted String? @map("amount_paid_formatted")
  total               Int?    @map("total")
  totalFormatted      String? @map("total_formatted")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("easyweek_booking_order")
}

model EasyweekOrderedService {
  id                     String   @id @default(uuid()) @db.Uuid
  detailsId              String   @map("extra_id") @db.Uuid
  details                EasyweekBookingDetails @relation(fields: [detailsId], references: [bookingId], onDelete: Cascade)
  externalUuid           String?  @map("external_uuid")
  timezone               String?  @map("timezone")
  reservedOn             DateTime? @map("reserved_on") @db.Timestamptz(6)
  reservedUntil          DateTime? @map("reserved_until") @db.Timestamptz(6)
  quantity               Int?     @map("quantity")
  name                   String?  @map("name")
  description            String?  @map("description")
  currency               String?  @map("currency")
  price                  Int?     @map("price")
  priceFormatted         String?  @map("price_formatted")
  discount               Int?     @map("discount")
  discountFormatted      String?  @map("discount_formatted")
  originalPrice          Int?     @map("original_price")
  originalPriceFormatted String?  @map("original_price_formatted")
  durationValue          Int?     @map("duration_value")
  durationLabel          String?  @map("duration_label")
  durationIso            String?  @map("duration_iso")
  originalDurationValue  Int?     @map("original_duration_value")
  originalDurationLabel  String?  @map("original_duration_label")
  originalDurationIso    String?  @map("original_duration_iso")
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([detailsId], map: "easyweek_ordered_services_extra_idx")
  @@map("easyweek_ordered_services")
}

// --- Altegio booking details ---
model AltegioBookingDetails {
  bookingId        String   @id @map("booking_id") @db.Uuid
  booking          Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  crmRecordId      String?  @map("crm_record_id")
  companyId        String?  @map("company_id")
  staffId          String?  @map("staff_id")
  clientId         String?  @map("client_id")
  datetime         DateTime? @map("datetime") @db.Timestamptz(6)
  date             DateTime? @map("date") @db.Timestamptz(6)
  createDate       DateTime? @map("create_date") @db.Timestamptz(6)
  comment          String?   @map("comment")
  online           Boolean?  @map("online")
  attendance       Int?      @map("attendance")
  visitAttendance  Int?      @map("visit_attendance")
  confirmed        Int?      @map("confirmed")
  seanceLength     Int?      @map("seance_length")
  length           Int?      @map("length")
  technicalBreak   Int?      @map("technical_break_duration")
  smsBefore        Int?      @map("sms_before")
  smsNow           Int?      @map("sms_now")
  emailNow         Int?      @map("email_now")
  notified         Int?      @map("notified")
  masterRequest    Int?      @map("master_request")
  apiId            String?   @map("api_id")
  fromUrl          String?   @map("from_url")
  reviewRequested  Int?      @map("review_requested")
  visitId          String?   @map("visit_id")
  createdUserId    String?   @map("created_user_id")
  deleted          Boolean?  @map("deleted")
  paidFull         Int?      @map("paid_full")
  prepaid          Boolean?  @map("prepaid")
  prepaidConfirmed Boolean?  @map("prepaid_confirmed")
  isUpdateBlocked  Boolean?  @map("is_update_blocked")
  lastChangeDate   DateTime? @map("last_change_date") @db.Timestamptz(6)
  customColor      String?   @map("custom_color")
  customFontColor  String?   @map("custom_font_color")
  smsRemainHours   Int?      @map("sms_remain_hours")
  emailRemainHours Int?      @map("email_remain_hours")
  bookformId       Int?      @map("bookform_id")
  recordFrom       String?   @map("record_from")
  isMobile         Int?      @map("is_mobile")
  shortLink        String?   @map("short_link")
  rawPayload       Json?     @map("raw_payload")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  staff            AltegioBookingStaff?
  client           AltegioBookingClient?
  services         AltegioBookingService[]
  documents        AltegioBookingDocument[]
  goodsTransactions AltegioBookingGoodsTransaction[]

  @@map("altegio_booking_details")
}

model AltegioBookingStaff {
  detailsId    String   @id @map("details_id") @db.Uuid
  details      AltegioBookingDetails @relation(fields: [detailsId], references: [bookingId], onDelete: Cascade)
  externalId   String?  @map("external_id")
  apiId        String?  @map("api_id")
  name         String?  @map("name")
  specialization String? @map("specialization")
  position     Json?    @map("position")
  avatar       String?  @map("avatar")
  avatarBig    String?  @map("avatar_big")
  rating       Float?   @map("rating")
  votesCount   Int?     @map("votes_count")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("altegio_booking_staff")
}

model AltegioBookingClient {
  detailsId        String   @id @map("details_id") @db.Uuid
  details          AltegioBookingDetails @relation(fields: [detailsId], references: [bookingId], onDelete: Cascade)
  externalId       String?  @map("external_id")
  name             String?  @map("name")
  surname          String?  @map("surname")
  patronymic       String?  @map("patronymic")
  displayName      String?  @map("display_name")
  comment          String?  @map("comment")
  phone            String?  @map("phone")
  card             String?  @map("card")
  email            String?  @map("email")
  successVisits    Int?     @map("success_visits_count")
  failVisits       Int?     @map("fail_visits_count")
  discount         Int?     @map("discount")
  sex              Int?     @map("sex")
  birthday         String?  @map("birthday")
  clientTags       Json?    @map("client_tags")
  customFields     Json?    @map("custom_fields")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("altegio_booking_client")
}

model AltegioBookingService {
  id             String   @id @default(uuid()) @db.Uuid
  detailsId      String   @map("details_id") @db.Uuid
  details        AltegioBookingDetails @relation(fields: [detailsId], references: [bookingId], onDelete: Cascade)
  externalId     String?  @map("external_id")
  title          String?  @map("title")
  cost           Int?     @map("cost")
  costToPay      Int?     @map("cost_to_pay")
  manualCost     Int?     @map("manual_cost")
  costPerUnit    Int?     @map("cost_per_unit")
  discount       Int?     @map("discount")
  firstCost      Int?     @map("first_cost")
  amount         Int?     @map("amount")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([detailsId], map: "altegio_booking_services_details_idx")
  @@map("altegio_booking_services")
}

model AltegioBookingDocument {
  id             String   @id @default(uuid()) @db.Uuid
  detailsId      String   @map("details_id") @db.Uuid
  details        AltegioBookingDetails @relation(fields: [detailsId], references: [bookingId], onDelete: Cascade)
  externalId     String?  @map("external_id")
  typeId         Int?     @map("type_id")
  storageId      Int?     @map("storage_id")
  userId         Int?     @map("user_id")
  companyId      Int?     @map("company_id")
  number         Int?     @map("number")
  comment        String?  @map("comment")
  dateCreated    DateTime? @map("date_created") @db.Timestamptz(6)
  categoryId     Int?     @map("category_id")
  visitId        String?  @map("visit_id")
  recordId       String?  @map("record_id")
  typeTitle      String?  @map("type_title")
  isSaleBillPrinted Boolean? @map("is_sale_bill_printed")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([detailsId], map: "altegio_booking_documents_details_idx")
  @@map("altegio_booking_documents")
}

model AltegioBookingGoodsTransaction {
  id             String   @id @default(uuid()) @db.Uuid
  detailsId      String   @map("details_id") @db.Uuid
  details        AltegioBookingDetails @relation(fields: [detailsId], references: [bookingId], onDelete: Cascade)
  externalId     String?  @map("external_id")
  typeId         Int?     @map("type_id")
  storageId      Int?     @map("storage_id")
  userId         Int?     @map("user_id")
  companyId      Int?     @map("company_id")
  number         Int?     @map("number")
  comment        String?  @map("comment")
  dateCreated    DateTime? @map("date_created") @db.Timestamptz(6)
  categoryId     Int?     @map("category_id")
  visitId        String?  @map("visit_id")
  recordId       String?  @map("record_id")
  typeTitle      String?  @map("type_title")
  isSaleBillPrinted Boolean? @map("is_sale_bill_printed")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([detailsId], map: "altegio_booking_goods_details_idx")
  @@map("altegio_booking_goods_transactions")
}

model CrmPairingCode {
  id        String    @id @default(uuid()) @db.Uuid
  provider  String
  userId    String    @map("user_id") @db.Uuid
  salonId   String?   @map("salon_id") @db.Uuid
  codeHash  String    @map("code_hash")
  attempts  Int       @default(0)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([provider, expiresAt], map: "crm_pairing_codes_provider_exp_idx")
  @@map("crm_pairing_codes")
}

// --- CRM credential storage (encrypted secrets) ---
model CrmCredential {
  id         String   @id @default(cuid())
  salonId    String   @db.Uuid
  provider   String
  cipherText Bytes
  iv         Bytes
  authTag    Bytes
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([salonId, provider])
}

// --- CRM account registry (non-secrets) ---
model CrmAccount {
  id        String   @id @default(cuid())
  salonId   String   @db.Uuid
  provider  String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([salonId, provider])
  @@index([provider])
}

model CrmSalonLastHash {
  salonId     String   @map("salon_id") @db.Uuid
  provider    String   @map("provider")
  fieldPath   String   @map("field_path")
  lastCrmHash String   @map("last_crm_hash")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  salon Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@id([salonId, provider, fieldPath])
  @@map("crm_salon_last_hash")
}

model CrmSalonChangeProposal {
  id         String               @id @default(uuid()) @db.Uuid
  salonId    String               @map("salon_id") @db.Uuid
  provider   String               @map("provider")
  fieldPath  String               @map("field_path")
  oldValue   Json?                @map("old_value")
  newValue   Json?                @map("new_value")
  newHash    String               @map("new_hash")
  status     CrmSalonChangeStatus @default(pending) @map("status")
  detectedAt DateTime             @map("detected_at") @db.Timestamptz(6)
  decidedAt  DateTime?            @map("decided_at") @db.Timestamptz(6)
  decidedBy  String?              @map("decided_by") @db.Uuid

  salon Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@unique([salonId, fieldPath, newHash], map: "crm_salon_change_proposal_unique_hash")
  @@index([salonId, status], map: "crm_salon_change_proposal_salon_status_idx")
  @@map("crm_salon_change_proposal")
}

model CrmSalonSnapshot {
  id          String   @id @default(uuid()) @db.Uuid
  salonId     String   @map("salon_id") @db.Uuid
  provider    String   @map("provider")
  payloadJson Json     @map("payload_json")
  payloadHash String   @map("payload_hash")
  fetchedAt   DateTime @map("fetched_at") @db.Timestamptz(6)

  salon Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@index([salonId, fetchedAt], map: "crm_salon_snapshot_salon_fetched_idx")
  @@map("crm_salon_snapshot")
}

// --- Sync & Reconciliation (MVP) ---
model SyncShadow {
  id              String   @id @default(cuid())
  entityType      String
  entityId        String   @db.Uuid
  provider        String
  externalId      String
  remote          Json
  remoteUpdatedAt String?
  remoteVersion   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([entityType, entityId, provider])
}

model SyncOutbox {
  id             String    @id @default(cuid())
  salonId        String    @db.Uuid
  entityType     String
  entityId       String    @db.Uuid
  provider       String
  op             String
  payload        Json
  idempotencyKey String?
  status         String    @default("pending")
  attempts       Int       @default(0)
  nextRunAt      DateTime?
  lastError      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status, nextRunAt])
}

model SearchHistory {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  salonId   String   @map("salon_id") @db.Uuid
  lastQuery String?  @map("last_query")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user  Users @relation(fields: [userId], references: [id], onDelete: Cascade)
  salon Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@unique([userId, salonId], map: "uniq_search_history_user_salon")
  @@index([userId, updatedAt], map: "idx_search_history_user_updated")
  @@index([createdAt], map: "idx_search_history_created_at")
  @@map("search_history")
}

// Simple mapping tables (composite unique)
model CategoryMapping {
  id         String @id @default(cuid())
  provider   String
  externalId String
  categoryId String @db.Uuid

  @@unique([provider, externalId])
  @@index([categoryId])
}

model ServiceMapping {
  id         String @id @default(cuid())
  provider   String
  externalId String
  serviceId  String @db.Uuid

  @@unique([provider, externalId])
  @@index([serviceId])
}

model WorkerMapping {
  id         String @id @default(cuid())
  provider   String
  externalId String
  workerId   String @db.Uuid

  @@unique([provider, externalId])
  @@index([workerId])
}
