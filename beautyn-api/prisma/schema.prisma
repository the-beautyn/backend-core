generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled, transaction mode (6543) + ?pgbouncer=true
  directUrl = env("DIRECT_URL") // direct/session mode (5432) for migrations
}

model SubscriptionPlan {
  id           String   @id @db.Uuid
  name         String   @db.VarChar(120)
  description  String
  priceCents   Int      @map("price_cents")
  currency     String   @db.Char(3)
  durationDays Int      @map("duration_days")
  features     Json
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  users        Users[]

  @@map("subscription_plan")
}

model Users {
  id                    String            @id @db.Uuid
  email                 String            @unique @db.VarChar(255)
  role                  UserRole          @default(client)
  name                  String?           @db.VarChar(100)
  secondName            String?           @map("second_name") @db.VarChar(100)
  phone                 String?           @db.VarChar(30)
  avatarUrl             String?           @map("avatar_url")
  isProfileCreated      Boolean           @default(false) @map("is_profile_created")
  isOnboardingCompleted Boolean           @default(false) @map("is_onboarding_completed")
  subscriptionId        String?           @map("subscription_id") @db.Uuid
  crmId                 String?           @map("crm_id")
  createdAt             DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime          @default(now()) @map("updated_at") @db.Timestamptz(6)
  subscriptionPlan      SubscriptionPlan? @relation(fields: [subscriptionId], references: [id])
  onboardingStep        OnboardingStep?
  salon                 Salon?            @relation("UserSalons")

  @@map("users")
}

/// Enum mapped to existing Postgres type `user_role`
enum UserRole {
  client @map("client")
  owner  @map("owner")
  admin  @map("admin")

  @@map("user_role")
}

enum OnboardingStepState {
  CRM
  SALON_PROFILE
  SUBSCRIPTION
  COMPLETED

  @@map("onboarding_step_state")
}

enum CrmSalonChangeStatus {
  pending   @map("pending")
  accepted  @map("accepted")
  dismissed @map("dismissed")

  @@map("crm_salon_change_status")
}

model OnboardingStep {
  id              String              @id @default(uuid()) @db.Uuid
  userId          String              @unique @map("user_id") @db.Uuid
  crmConnected    Boolean             @default(false) @map("crm_connected")
  salonCreated    Boolean             @default(false) @map("salon_created")
  subscriptionSet Boolean             @default(false) @map("subscription_set")
  currentStep     OnboardingStepState @default(CRM) @map("current_step")
  completed       Boolean             @default(false)
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  user Users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("onboarding_step")
}

model Salon {
  id              String    @id @default(uuid()) @db.Uuid
  crmId           String?   @map("crm_id")
  // CRM link (draft onboarding support)
  // externalSalonId stores provider-specific external id (stringified)
  externalSalonId String?   @map("external_salon_id")
  // provider stores which CRM this salon is linked to (e.g., 'ALTEGIO' | 'EASYWEEK')
  provider        String?   @map("provider")
  // owner user link (used for onboarding flows)
  ownerUserId     String?   @map("owner_user_id") @db.Uuid
  owner           Users?    @relation("UserSalons", fields: [ownerUserId], references: [id], onDelete: SetNull)
  name            String?
  description     String?   @map("description")
  addressLine     String?   @map("address_line")
  city            String?
  country         String?   @db.VarChar(64)
  latitude        Decimal?  @db.Decimal(9, 6)
  longitude       Decimal?  @db.Decimal(9, 6)
  timezone        String?   @map("timezone")
  phone           String?
  email           String?
  ratingAvg       Decimal?  @map("rating_avg") @db.Decimal(2, 1)
  ratingCount     Int?      @map("rating_count")
  openHoursJson   Json?     @map("open_hours_json")
  workingSchedule String?   @map("working_schedule")
  imagesCount     Int?      @map("images_count")
  coverImageUrl   String?   @map("cover_image_url")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  images             SalonImage[]
  categories         Category[]
  services           Service[]
  crmHashes          CrmSalonLastHash[]
  crmChangeProposals CrmSalonChangeProposal[]
  crmSnapshots       CrmSalonSnapshot[]

  @@unique([ownerUserId], map: "uniq_salon_owner")
  @@index([latitude, longitude])
  @@index([ownerUserId], map: "idx_salon_owner")
  @@map("salons")
}

model SalonImage {
  id        String   @id @default(uuid()) @db.Uuid
  salonId   String   @map("salon_id") @db.Uuid
  imageUrl  String   @map("image_url")
  caption   String?
  sortOrder Int?     @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  salon Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@index([salonId, sortOrder])
  @@map("salon_images")
}

model Category {
  id            String   @id @default(uuid()) @db.Uuid
  salonId       String   @map("salon_id") @db.Uuid
  crmCategoryId String?  @map("crm_category_id") @db.VarChar(64)
  name          String   @db.VarChar(120)
  color         String?  @db.VarChar(7)
  sortOrder     Int?     @map("sort_order")
  serviceIds    String[] @default([]) @map("service_ids") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  salon    Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade)
  services Service[]

  @@index([salonId, sortOrder], map: "idx_category_salon_sort")
  @@map("categories")
}

model Service {
  id           String   @id @default(uuid()) @db.Uuid
  salonId      String   @map("salon_id") @db.Uuid
  crmServiceId String?  @map("crm_service_id")
  categoryId   String?  @map("category_id") @db.Uuid
  name         String   @db.VarChar(160)
  description  String?
  duration     Int
  price        Int
  currency     String   @db.Char(3)
  sortOrder    Int?     @map("sort_order")
  workerIds    String[] @map("worker_ids")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  salon    Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id])

  @@index([salonId, isActive])
  @@index([categoryId, isActive])
  @@map("services")
}

model Worker {
  id           String   @id @default(uuid()) @db.Uuid
  salonId      String   @map("salon_id") @db.Uuid
  firstName    String   @map("first_name") @db.VarChar(100)
  lastName     String   @map("last_name") @db.VarChar(100)
  role         String?  @db.VarChar(100)
  email        String?  @unique @db.VarChar(255)
  phone        String?  @unique @db.VarChar(30)
  photoUrl     String?  @map("photo_url")
  workSchedule Json?    @map("work_schedule")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  services WorkerService[]

  @@index([salonId, firstName])
  @@index([salonId, lastName])
  @@map("workers")
}

model WorkerService {
  workerId  String @map("worker_id") @db.Uuid
  serviceId String @map("service_id") @db.Uuid

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  // Service model exists in another branch; FK can be added later.
  @@id([workerId, serviceId])
  @@map("worker_services")
}

model CrmPairingCode {
  id        String    @id @default(uuid()) @db.Uuid
  provider  String
  userId    String    @map("user_id") @db.Uuid
  salonId   String?   @map("salon_id") @db.Uuid
  codeHash  String    @map("code_hash")
  attempts  Int       @default(0)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([provider, expiresAt], map: "crm_pairing_codes_provider_exp_idx")
  @@map("crm_pairing_codes")
}

// --- CRM credential storage (encrypted secrets) ---
model CrmCredential {
  id         String   @id @default(cuid())
  salonId    String   @db.Uuid
  provider   String
  cipherText Bytes
  iv         Bytes
  authTag    Bytes
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([salonId, provider])
}

// --- CRM account registry (non-secrets) ---
model CrmAccount {
  id        String   @id @default(cuid())
  salonId   String   @db.Uuid
  provider  String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([salonId, provider])
  @@index([provider])
}

model CrmSalonLastHash {
  salonId     String   @map("salon_id") @db.Uuid
  provider    String   @map("provider")
  fieldPath   String   @map("field_path")
  lastCrmHash String   @map("last_crm_hash")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  salon Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@id([salonId, provider, fieldPath])
  @@map("crm_salon_last_hash")
}

model CrmSalonChangeProposal {
  id         String               @id @default(uuid()) @db.Uuid
  salonId    String               @map("salon_id") @db.Uuid
  provider   String               @map("provider")
  fieldPath  String               @map("field_path")
  oldValue   Json?                @map("old_value")
  newValue   Json?                @map("new_value")
  newHash    String               @map("new_hash")
  status     CrmSalonChangeStatus @default(pending) @map("status")
  detectedAt DateTime             @map("detected_at") @db.Timestamptz(6)
  decidedAt  DateTime?            @map("decided_at") @db.Timestamptz(6)
  decidedBy  String?              @map("decided_by") @db.Uuid

  salon Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@unique([salonId, fieldPath, newHash], map: "crm_salon_change_proposal_unique_hash")
  @@index([salonId, status], map: "crm_salon_change_proposal_salon_status_idx")
  @@map("crm_salon_change_proposal")
}

model CrmSalonSnapshot {
  id          String   @id @default(uuid()) @db.Uuid
  salonId     String   @map("salon_id") @db.Uuid
  provider    String   @map("provider")
  payloadJson Json     @map("payload_json")
  payloadHash String   @map("payload_hash")
  fetchedAt   DateTime @map("fetched_at") @db.Timestamptz(6)

  salon Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@index([salonId, fetchedAt], map: "crm_salon_snapshot_salon_fetched_idx")
  @@map("crm_salon_snapshot")
}

// --- Sync & Reconciliation (MVP) ---
model SyncShadow {
  id              String   @id @default(cuid())
  entityType      String
  entityId        String   @db.Uuid
  provider        String
  externalId      String
  remote          Json
  remoteUpdatedAt String?
  remoteVersion   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([entityType, entityId, provider])
}

model SyncOutbox {
  id             String    @id @default(cuid())
  salonId        String    @db.Uuid
  entityType     String
  entityId       String    @db.Uuid
  provider       String
  op             String
  payload        Json
  idempotencyKey String?
  status         String    @default("pending")
  attempts       Int       @default(0)
  nextRunAt      DateTime?
  lastError      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status, nextRunAt])
}

// Simple mapping tables (composite unique)
model CategoryMapping {
  id         String @id @default(cuid())
  provider   String
  externalId String
  categoryId String @db.Uuid

  @@unique([provider, externalId])
  @@index([categoryId])
}

model ServiceMapping {
  id         String @id @default(cuid())
  provider   String
  externalId String
  serviceId  String @db.Uuid

  @@unique([provider, externalId])
  @@index([serviceId])
}

model WorkerMapping {
  id         String @id @default(cuid())
  provider   String
  externalId String
  workerId   String @db.Uuid

  @@unique([provider, externalId])
  @@index([workerId])
}
